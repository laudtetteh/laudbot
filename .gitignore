# Approved source data — never committed
# Ignore all content in approved subdirs, but preserve .gitkeep markers
data/approved/resume/*
!data/approved/resume/.gitkeep
data/approved/exports/*
!data/approved/exports/.gitkeep
data/approved/writeups/*
!data/approved/writeups/.gitkeep

