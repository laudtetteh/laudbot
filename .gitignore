# Archive folder — local holding area, never committed
data/_archive/

# Approved source data — never committed
# Ignore all content in approved subdirs, but preserve .gitkeep markers
data/approved/resume/*
!data/approved/resume/.gitkeep
data/approved/exports/*
!data/approved/exports/.gitkeep
data/approved/writeups/*
!data/approved/writeups/.gitkeep
# Ignore the live system prompt (personal content) — the .example template is committed
data/approved/system_prompt.md
# Ignore live mode overlay files (personal content) — tracked dir via .gitkeep
data/approved/overlays/*.md
# Ignore live mode prompt files (personal content) — tracked dir via .gitkeep
data/approved/prompts/*.txt
!data/approved/prompts/.gitkeep

# Environment variables
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Node
node_modules/
.next/
out/
.npm
*.tsbuildinfo

# Docker
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Agentic coding — personal session state (don't commit)
# Note: CONTEXT_SNAPSHOT.md IS tracked — future Claude sessions need it from the repo
prompts/history