# ============================================================
# LaudBot — environment variable reference
# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Columns:
#   LOCAL   = Docker Compose local dev
#   CI      = GitHub Actions (build + deploy pipeline)
#   DO      = DigitalOcean App Platform (production)
#
# SECRET  = must be stored as an encrypted secret (never plain text in source)
# VALUE   = non-sensitive, safe to version-control in app.yaml or workflow files
# AUTO    = injected automatically — do not set manually
# N/A     = not used in this environment
# ============================================================

# ------------------------------------------------------------
# LLM providers                         LOCAL  CI    DO
# ------------------------------------------------------------

# Anthropic Claude — primary LLM        VALUE  N/A   SECRET
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — optional fallback provider   VALUE  N/A   SECRET
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional model overrides (defaults: claude-opus-4-6, gpt-4o)
# CLAUDE_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------
# Admin auth                            LOCAL  CI    DO
# ------------------------------------------------------------

#                                        VALUE  N/A   SECRET
ADMIN_USERNAME=xxxx
ADMIN_PASSWORD=xxxx

# Generate for production: openssl rand -hex 32
#                                        VALUE  N/A   SECRET
JWT_SECRET_KEY=xxxx
JWT_EXPIRE_HOURS=24

# ------------------------------------------------------------
# Database                              LOCAL  CI    DO
# ------------------------------------------------------------

# Full PostgreSQL connection string.
# LOCAL: use the Docker Compose postgres service hostname.
#        docker-compose.yml injects this automatically — only set here if
#        running the backend outside Docker (bare local dev).
# DO: injected automatically from the managed DB cluster via ${db.DATABASE_URL}
#     in app.yaml. Do NOT set this manually in the DO dashboard.
#                                        VALUE  N/A   AUTO
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=

# Individual Postgres vars — used by docker-compose.yml to initialise the
# local postgres service. Required for local Docker Compose. Not used in CI or DO.
# Copy these to your .env and set values — they are never committed.
#                                        VALUE  N/A   N/A
POSTGRES_DB=xxxx
POSTGRES_USER=xxxx
POSTGRES_PASSWORD=xxxx

# ------------------------------------------------------------
# System prompt                         LOCAL  CI    DO
# ------------------------------------------------------------

# PRODUCTION: set the full system prompt content as a secret env var in DO.
# This takes priority over the file path below.
#                                        N/A    N/A   SECRET
# SYSTEM_PROMPT=You are LaudBot...

# LOCAL: leave SYSTEM_PROMPT unset. The backend reads from the volume-mounted
# file instead. Copy data/approved/system_prompt.md.example → system_prompt.md
# and fill it in. Override the path only if you move the file.
# SYSTEM_PROMPT_PATH=/data/approved/system_prompt.md

# ------------------------------------------------------------
# Mode overlays                         LOCAL  CI    DO
# ------------------------------------------------------------

# PRODUCTION: set full overlay content as a secret env var in DO.
# Takes priority over the volume-mounted .md files used in local dev.
# Each var maps to one mode; leave unset locally (file fallback is used instead).
#                                        N/A    N/A   SECRET
# OVERLAY_PROFESSIONAL=## Professional mode overlay\n\nYour content here...
# OVERLAY_PEER=## Peer mode overlay\n\nYour content here...
# OVERLAY_BUDDY=## Buddy mode overlay\n\nYour content here...

# ------------------------------------------------------------
# Suggested prompts                     LOCAL  CI    DO
# ------------------------------------------------------------

# PRODUCTION: newline-separated list of prompts per mode.
# DB is seeded from these on first boot (ON CONFLICT DO NOTHING — admin edits persist).
# Leave unset locally if managing prompts via the admin UI.
#                                        N/A    N/A   SECRET
# SUGGESTED_PROMPTS_PROFESSIONAL=Tell me about your experience\nWhat projects have you shipped?\nHow do you approach system design?
# SUGGESTED_PROMPTS_PEER=What are you building right now?\nWhat's your take on AI-assisted coding?\nHow do you handle technical debt?
# SUGGESTED_PROMPTS_BUDDY=What's your hot take on the industry?\nWhat are you learning lately?\nGive me the unfiltered version.

# ------------------------------------------------------------
# Email (Resend)                        LOCAL  CI    DO
# ------------------------------------------------------------

# Required to send invite emails.       VALUE  N/A   SECRET
# Get yours at: https://resend.com/api-keys
# If unset, invite generation works but no email is delivered.
RESEND_API_KEY=

# From address — must be a verified sender in your Resend account.
# Defaults to: LaudBot <hello@laudtetteh.io>
#                                        VALUE  N/A   SECRET
# RESEND_FROM_EMAIL=LaudBot <hello@laudtetteh.io>

# ------------------------------------------------------------
# URLs                                  LOCAL  CI    DO
# ------------------------------------------------------------

# Frontend URL — used to build invite links.
#                                        VALUE  N/A   VALUE (app.yaml)
FRONTEND_URL=http://localhost:3001

# Backend URL for Next.js server-side proxy rewrite.
# Docker Compose sets this automatically via docker-compose.yml.
# Only set this if running Next.js outside Docker.
#                                        AUTO   N/A   VALUE (app.yaml)
# BACKEND_URL=http://localhost:8000
