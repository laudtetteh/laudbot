# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ------------------------------------------------------------
# LLM providers
# ------------------------------------------------------------

# Anthropic Claude API key — required to use Claude as the LLM provider.
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI API key — required only if you want to use OpenAI as the provider.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override the default model for each provider.
# Defaults: claude-opus-4-6, gpt-4o
# CLAUDE_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------
# System prompt
# ------------------------------------------------------------

# PRODUCTION (DO App Platform): set the full system prompt content here as a
# secret env var. This takes priority over the file path below.
# SYSTEM_PROMPT=You are LaudBot...

# LOCAL (Docker Compose): leave SYSTEM_PROMPT unset and use the volume-mounted
# file instead. Copy data/approved/system_prompt.md.example to
# data/approved/system_prompt.md and fill it in.
# Override the path only if you move the file.
# SYSTEM_PROMPT_PATH=/data/approved/system_prompt.md

# ------------------------------------------------------------
# Frontend (only needed for bare local dev outside Docker)
# In Docker Compose this is set automatically via docker-compose.yml
# ------------------------------------------------------------

# Backend URL for Next.js server-side proxy rewrite.
# Docker Compose sets this to http://backend:8000 automatically.
# Only set this if running Next.js outside Docker.
# BACKEND_URL=http://localhost:8000

# ------------------------------------------------------------
# Database (v2+ — not required yet)
# ------------------------------------------------------------

# PostgreSQL connection string. Not needed until the retrieval layer is built.
# DATABASE_URL=postgresql://user:password@localhost:5432/laudbot

# Admin auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_EXPIRE_HOURS=24

# Frontend URL (used to build invite links)
FRONTEND_URL=http://localhost:3001

# ------------------------------------------------------------
# Email (Resend)
# ------------------------------------------------------------

# Resend API key — required to send invite emails.
# Get yours at: https://resend.com/api-keys
# If unset, invite generation still works but no email is sent.
RESEND_API_KEY=

# From address for invite emails. Must be a verified sender in your Resend account.
# Defaults to: LaudBot <hello@laudtetteh.io>
# RESEND_FROM_EMAIL=LaudBot <hello@laudtetteh.io>
